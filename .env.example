# ─────────────────────────────────────────────────────────────────────────────
#  FLOS — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="FLOS Fleet Management"
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── PostgreSQL (Docker Compose) ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=fleet-shuufare

# ── Database URL ──────────────────────────────────────────────────────────────
# For local dev (outside Docker): uncomment below and fill in your local PG credentials
# DATABASE_URL=postgresql://postgres:password@localhost:5432/fleet-shuufare

# For Docker Compose: this is set automatically in docker-compose.yml
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Yango Fleet API ───────────────────────────────────────────────────────────
YANGO_BASE_URL=https://fleet-api.yango.tech
YANGO_API_KEY=your-yango-api-key-here
YANGO_CLIENT_ID=taxi/park/your-park-id-here
YANGO_PARK_ID=your-park-id-here

# ── SMS Gateway (PlaySMS — optional) ─────────────────────────────────────────
PLAYSMS_URL=https://your-playsms-host/index.php
PLAYSMS_USER=your-playsms-username
PLAYSMS_TOKEN=your-playsms-token

# ── Seeding (set to true only on first run to seed initial data) ──────────────
SEED_DB=false
